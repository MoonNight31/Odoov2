<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions pour séparer personnes et structures -->
    <record id="action_limayrac_person" model="ir.actions.act_window">
        <field name="name">Personnes</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('is_company', '=', False)]</field>
        <field name="context">{'default_is_company': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer une nouvelle personne
            </p>
            <p>
                Gérez ici les candidats, apprenants, intervenants et tuteurs.
            </p>
        </field>
    </record>

    <record id="action_limayrac_company" model="ir.actions.act_window">
        <field name="name">Structures</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('is_company', '=', True)]</field>
        <field name="context">{'default_is_company': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer une nouvelle structure
            </p>
            <p>
                Gérez ici les entreprises et organisations partenaires.
            </p>
        </field>
    </record>

    <!-- Menu principal Limayrac -->
    <menuitem id="menu_limayrac_root"
              name="Limayrac"
              sequence="10"/>

    <!-- Menu Contacts -->
    <menuitem id="menu_limayrac_contacts"
              name="Contacts"
              parent="menu_limayrac_root"
              sequence="10"/>

    <menuitem id="menu_limayrac_contacts_person"
              name="Personnes"
              parent="menu_limayrac_contacts"
              action="action_limayrac_person"
              sequence="10"/>

    <menuitem id="menu_limayrac_contacts_company"
              name="Structures"
              parent="menu_limayrac_contacts"
              action="action_limayrac_company"
              sequence="20"/>

    <menuitem id="menu_limayrac_service"
              name="Services"
              parent="menu_limayrac_contacts"
              action="action_limayrac_service"
              sequence="30"/>

    <menuitem id="menu_limayrac_groupe_structure"
              name="Groupes"
              parent="menu_limayrac_contacts"
              action="action_limayrac_groupe_structure"
              sequence="40"/>

    <menuitem id="menu_limayrac_type_activite"
              name="Types d'activité"
              parent="menu_limayrac_contacts"
              action="action_limayrac_type_activite"
              sequence="50"/>
</odoo>
