<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue arbre -->
    <record id="view_limayrac_voeux_tree" model="ir.ui.view">
        <field name="name">limayrac.voeux.tree</field>
        <field name="model">limayrac.voeux</field>
        <field name="arch" type="xml">
            <tree decoration-success="statut_dossier == 'accepte'" 
                  decoration-danger="statut_dossier == 'refuse'" 
                  decoration-muted="statut_dossier == 'annule'">
                <field name="id_voeux"/>
                <field name="apprenant_id"/>
                <field name="formation_id"/>
                <field name="date_candidature"/>
                <field name="statut_dossier"/>
                <field name="statut_SRE"/>
                <field name="Date_Jury"/>
                <field name="Note_Moyenne"/>
                <field name="is_alternant"/>
            </tree>
        </field>
    </record>

    <!-- Vue formulaire -->
    <record id="view_limayrac_voeux_form" model="ir.ui.view">
        <field name="name">limayrac.voeux.form</field>
        <field name="model">limayrac.voeux</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accepter" string="Accepter" type="object" 
                            class="oe_highlight" invisible="statut_dossier in ['accepte', 'refuse', 'annule']"/>
                    <button name="action_refuser" string="Refuser" type="object" 
                            invisible="statut_dossier in ['accepte', 'refuse', 'annule']"/>
                    <button name="action_annuler" string="Annuler" type="object" 
                            invisible="statut_dossier in ['refuse', 'annule']"/>
                    <field name="statut_dossier" widget="statusbar" 
                           statusbar_visible="nouveau,en_cours,accepte"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="id_voeux" invisible="1"/>
                    </div>
                    <group>
                        <group string="Informations du candidat">
                            <field name="apprenant_id"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="date_candidature"/>
                        </group>
                        <group string="Formation et entreprise">
                            <field name="formation_id"/>
                            <field name="entreprise_id"/>
                            <field name="activite_id"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Statuts">
                            <field name="statut_SRE"/>
                            <field name="is_besoin"/>
                            <field name="is_kairos"/>
                            <field name="is_alternant"/>
                            <field name="is_presenceCoaching"/>
                        </group>
                        <group string="Jury">
                            <field name="Date_Jury"/>
                            <field name="jury1_id"/>
                            <field name="jury2_id"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Notes et Commentaires">
                            <group>
                                <group string="Commentaires (Texte)">
                                    <field name="Note_RP" placeholder="Commentaire RP..."/>
                                    <field name="Note_CFP" placeholder="Commentaire CFP..."/>
                                    <field name="Note_SRE" placeholder="Commentaire SRE..."/>
                                    <field name="Note_Jury" placeholder="Commentaire Jury..."/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Notes de Questions">
                            <group>
                                <group string="Notation (Chiffres)">
                                    <field name="Note_Q1"/>
                                    <field name="Note_Q2"/>
                                    <field name="Note_Q3"/>
                                    <field name="Note_Q4"/>
                                    <field name="Note_Q5"/>
                                    <field name="Note_Moyenne" readonly="1" widget="progressbar"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Description Mission">
                            <field name="description_mission" placeholder="Description de la mission..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue recherche -->
    <record id="view_limayrac_voeux_search" model="ir.ui.view">
        <field name="name">limayrac.voeux.search</field>
        <field name="model">limayrac.voeux</field>
        <field name="arch" type="xml">
            <search>
                <field name="apprenant_id"/>
                <field name="formation_id"/>
                <field name="entreprise_id"/>
                <filter string="Nouveau" name="nouveau" domain="[('statut_dossier', '=', 'nouveau')]"/>
                <filter string="En cours" name="en_cours" domain="[('statut_dossier', '=', 'en_cours')]"/>
                <filter string="Accepté" name="accepte" domain="[('statut_dossier', '=', 'accepte')]"/>
                <filter string="Refusé" name="refuse" domain="[('statut_dossier', '=', 'refuse')]"/>
                <separator/>
                <filter string="Alternant" name="alternant" domain="[('is_alternant', '=', True)]"/>
                <filter string="Lié à un besoin" name="besoin" domain="[('is_besoin', '=', True)]"/>
                <filter string="Kaïros" name="kairos" domain="[('is_kairos', '=', True)]"/>
                <separator/>
                <filter string="Cette année" name="this_year" 
                        domain="[('date_candidature', '&gt;=', (context_today() - relativedelta(months=12)).strftime('%Y-01-01'))]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Formation" name="group_formation" context="{'group_by': 'formation_id'}"/>
                    <filter string="Statut Dossier" name="group_statut" context="{'group_by': 'statut_dossier'}"/>
                    <filter string="Statut SRE" name="group_sre" context="{'group_by': 'statut_SRE'}"/>
                    <filter string="Mois" name="group_month" context="{'group_by': 'date_candidature:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_limayrac_voeux" model="ir.actions.act_window">
        <field name="name">Candidatures</field>
        <field name="res_model">limayrac.voeux</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_nouveau': 1, 'search_default_en_cours': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créer une nouvelle candidature
            </p>
            <p>
                Les candidatures représentent les vœux des personnes souhaitant intégrer une formation.
            </p>
        </field>
    </record>
</odoo>
